#version 450
// Simple buffer copy: dst[i] = src[i]
layout(local_size_x = 256) in;

layout(std430, binding = 0) writeonly buffer DstBuf { float dst[]; };
layout(std430, binding = 1) readonly buffer SrcBuf { float src[]; };

layout(push_constant) uniform PushConstants { uint n; } pc;

void main() {
    uint i = gl_WorkGroupID.x * gl_WorkGroupSize.x + gl_LocalInvocationID.x;
    if (i < pc.n) dst[i] = src[i];
}
