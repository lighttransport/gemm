#version 450

layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    uint n;
} pc;

layout(std430, binding = 0) buffer XBuf { float x[]; };

void main() {
    uint i = gl_WorkGroupID.x * gl_WorkGroupSize.x + gl_LocalInvocationID.x;
    if (i < pc.n)
        x[i] = max(x[i], 0.0);
}
